{
  "name": "vue-fetch",
  "version": "3.1.0-0",
  "description": "Simplified fetch API for Vue 2+",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "prepublish": "npm run build",
    "test": "mocha"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bangbang93/vue-fetch.git"
  },
  "keywords": [
    "fetch",
    "vue"
  ],
  "author": "bangbang93",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bangbang93/vue-fetch/issues"
  },
  "homepage": "https://github.com/bangbang93/vue-fetch#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/debug": "0.0.30",
    "debug": "^3.1.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@tsconfig/recommended": "^1.0.13",
    "@types/mocha": "^2.2.48",
    "@types/node": "^20.19.37",
    "@types/should": "^13.0.0",
    "mocha": "^11.7.5",
    "release-it": "^19.2.4",
    "should": "^11.2.1",
    "ts-node": "^5.0.1",
    "tsdown": "^0.21.2",
    "typescript": "^5.0.0",
    "vue": "^3.2.45"
  },
  "peerDependencies": {
    "vue": "^3.2.45"
  }
}
